            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "PhantomBuster - Scrape": {
      "main": [
        [
          {
            "node": "Parse Profiles",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse Profiles": {
      "main": [
        [
          {
            "node": "AI - Personalize",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "AI - Personalize": {
      "main": [
        [
          {
            "node": "PhantomBuster - Connect",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "PhantomBuster - Connect": {
      "main": [
        [
          {
            "node": "Wait 3 Days",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Wait 3 Days": {
      "main": [
        [
          {
            "node": "AI - Follow-up",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "AI - Follow-up": {
      "main": [
        [
          {
            "node": "PhantomBuster - Message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "PhantomBuster - Message": {
      "main": [
        [
          {
            "node": "Log Outreach",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
